# Fireworks AI API key (get one at https://fireworks.ai — new AMD AI Developer
# Program members receive $50 in free Fireworks credits)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Your dedicated Gemma 4 26B A4B IT deployment ID on Fireworks, in the form:
# accounts/<your-account>/deployments/<deployment-id>
# Create one via: Fireworks dashboard -> Deployments -> New Deployment -> Gemma 4 26B A4B IT
GEMMA4_DEPLOYMENT_ID=accounts/your-account/deployments/your-deployment-id
